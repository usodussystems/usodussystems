{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Strictness */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    /* NOTE: no explicit "types" array. Test files import their APIs directly
       from 'vitest', and jest-dom matcher types are augmented via the import
       in src/test/setup.ts (part of this compilation), so we avoid narrowing
       the app's ambient @types/* (e.g. @types/react) by omitting "types". */

    /* Path mapping (mirrors vite.config.ts '@' -> ./src) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "build",
    "src/components/ui"
  ]
}
